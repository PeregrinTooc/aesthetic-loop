# Required: run `getent group render | cut -d: -f3` to find your value
RENDER_GID=

# ComfyUI — already running on the host
COMFYUI_BASE_URL=http://host.docker.internal:8188
# swap to :8190 for the zimage instance

# Path inside the orchestrator container where workflow.json is mounted
WORKFLOW_PATH=/workflow.json

# Filename of the SD checkpoint in ComfyUI's models/checkpoints/
SD_CHECKPOINT=v1-5-pruned-emaonly.ckpt

# Models (must be available in Ollama)
BOB_MODEL=gemma3:12b
ALICE_MODEL=mistral-small3.1:latest
DYLAN_MODEL=qwen2.5vl:7b

# Ollama endpoint as seen from inside the orchestrator container
OLLAMA_HOST=http://ollama:11434

# Loop settings
INITIAL_PROMPT=a mountain landscape at golden hour, photorealistic, cinematic lighting
MAX_ITERATIONS=50
MILESTONES=1,5,10,20,50

# Output directory inside the orchestrator container (bind-mounted to ./output)
OUTPUT_DIR=/output

# Uncomment and set if Ollama falls back to CPU instead of GPU
# HSA_OVERRIDE_GFX_VERSION=11.0.0
